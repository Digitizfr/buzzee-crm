---
const productLinks = [
  { label: 'Fonctionnalités', href: '#fonctionnalites' },
  { label: 'Tarifs', href: '#tarifs' },
  { label: 'Application mobile', href: '#' },
  { label: 'Intégrations', href: '#' },
];

const resourceLinks = [
  { label: 'Centre d\'aide', href: '#' },
  { label: 'Blog', href: '#' },
  { label: 'Formations', href: '#' },
  { label: 'API Documentation', href: '#' },
];

const companyLinks = [
  { label: 'À propos', href: '#' },
  { label: 'Contact', href: '#' },
  { label: 'Programme de parrainage', href: '#' },
  { label: 'Mentions légales', href: '#' },
];

const supportLinks = [
  { label: 'Support technique', href: '#' },
  { label: 'Politique de confidentialité', href: '#' },
  { label: 'CGV', href: '#' },
  { label: 'RGPD', href: '#' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="6" fill="#2E5748"/>
            <path d="M8 11h6c2.2 0 4 1.8 4 4s-1.8 4-4 4h-4v4H8V11zm2 2v4h4c1.1 0 2-.9 2-2s-.9-2-2-2h-4z" fill="white"/>
            <circle cx="22" cy="20" r="4" fill="#CEFEAB"/>
          </svg>
          <span>Buzzee</span>
        </a>
        <p class="footer__tagline">Le CRM français qui s'adapte à tous les métiers.</p>
        <div class="footer__contact">
          <a href="tel:0173057000" class="footer__phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            01 73 05 70 00
          </a>
        </div>
      </div>

      <div class="footer__links-group">
        <h4>Produit</h4>
        <ul>
          {productLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__links-group">
        <h4>Ressources</h4>
        <ul>
          {resourceLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__links-group">
        <h4>Société</h4>
        <ul>
          {companyLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__links-group">
        <h4>Support</h4>
        <ul>
          {supportLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} Buzzee CRM. Tous droits réservés. Hébergé en France.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--dark-bg);
    color: var(--dark-on);
    padding: var(--sp-16) 0 var(--sp-8);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.5fr repeat(4, 1fr);
    gap: var(--sp-8);
    padding-bottom: var(--sp-12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 1.25rem;
    font-weight: 800;
    color: white;
    margin-bottom: var(--sp-4);
  }

  .footer__tagline {
    color: var(--dark-muted);
    font-size: 0.9375rem;
    margin-bottom: var(--sp-4);
  }

  .footer__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--dark-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer__phone:hover {
    color: white;
  }

  .footer__links-group h4 {
    font-size: 0.875rem;
    font-weight: 700;
    margin-bottom: var(--sp-4);
    color: white;
  }

  .footer__links-group ul {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer__links-group a {
    font-size: 0.875rem;
    color: var(--dark-muted);
    transition: color 0.2s;
  }

  .footer__links-group a:hover {
    color: white;
  }

  .footer__bottom {
    padding-top: var(--sp-8);
    text-align: center;
  }

  .footer__bottom p {
    font-size: 0.8125rem;
    color: var(--dark-muted);
  }

  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-8);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>
