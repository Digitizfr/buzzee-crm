<section class="cta-section">
  <div class="container">
    <div class="cta-block">
      <h2 class="display-md cta-block__title">Prêt à simplifier votre gestion client ?</h2>
      <p class="cta-block__desc">
        Essayez Buzzee gratuitement pendant 30 jours. Sans engagement, sans carte bancaire.
      </p>
      <div class="cta-block__actions">
        <a href="#tarifs" class="btn btn--white">Démarrer l'essai gratuit</a>
        <a href="#" class="btn btn--ghost">Demander une démo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--sp-20) 0;
  }

  .cta-block {
    background: var(--dark-bg);
    border-radius: var(--radius-2xl);
    padding: var(--sp-16) var(--sp-8);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-block::before {
    content: '';
    position: absolute;
    top: -40%;
    left: -20%;
    width: 60%;
    height: 180%;
    background: radial-gradient(ellipse at center, rgba(206, 254, 171, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-block::after {
    content: '';
    position: absolute;
    bottom: -40%;
    right: -20%;
    width: 60%;
    height: 180%;
    background: radial-gradient(ellipse at center, rgba(206, 254, 171, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .cta-block__title {
    color: var(--dark-on);
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto var(--sp-4);
  }

  .cta-block__desc {
    color: var(--dark-muted);
    font-size: 1.125rem;
    max-width: 480px;
    margin: 0 auto var(--sp-8);
    position: relative;
    z-index: 1;
  }

  .cta-block__actions {
    display: flex;
    justify-content: center;
    gap: var(--sp-4);
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .cta-block {
      padding: var(--sp-12) var(--sp-6);
    }

    .cta-block__actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
