---
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__badge">CRM Francais #1</span>
      <h1 class="display-lg hero__title">
        Gérez vos contacts et votre business <span class="hero__highlight">simplement</span>
      </h1>
      <p class="hero__subtitle">
        Le CRM français qui s'adapte à tous les métiers. Que vous soyez PME, startup ou indépendant,
        Buzzee vous offre les outils pour booster votre activité et vos ventes.
      </p>
      <div class="hero__actions">
        <a href="#tarifs" class="btn btn--white">Essai gratuit</a>
        <a href="#" class="btn btn--ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
          Voir la démo
        </a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-value">10 000+</span>
          <span class="hero__stat-label">clients</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">98%</span>
          <span class="hero__stat-label">de satisfaction</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">4.5/5</span>
          <span class="hero__stat-label">sur Google</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-value">100%</span>
          <span class="hero__stat-label">hébergé en France</span>
        </div>
      </div>
    </div>
  </div>
  <div class="hero__gradient"></div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--dark-bg);
    padding: 10rem 0 6rem;
    overflow: hidden;
  }

  .hero__gradient {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 70%;
    height: 200%;
    background: radial-gradient(ellipse at center, rgba(206, 254, 171, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero__content {
    max-width: 720px;
  }

  .hero__badge {
    display: inline-block;
    padding: 6px 16px;
    background: rgba(206, 254, 171, 0.15);
    color: #CEFEAB;
    border-radius: var(--radius-full);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    margin-bottom: var(--sp-6);
  }

  .hero__title {
    color: var(--dark-on);
    margin-bottom: var(--sp-6);
  }

  .hero__highlight {
    background: linear-gradient(135deg, #CEFEAB, #7dd95e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__subtitle {
    font-size: 1.125rem;
    color: var(--dark-muted);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: var(--sp-8);
  }

  .hero__actions {
    display: flex;
    gap: var(--sp-4);
    margin-bottom: var(--sp-12);
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
  }

  .hero__stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--dark-on);
  }

  .hero__stat-label {
    font-size: 0.8125rem;
    color: var(--dark-muted);
  }

  .hero__stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 8rem 0 4rem;
    }

    .hero__stats {
      flex-wrap: wrap;
      gap: var(--sp-6);
    }

    .hero__stat-divider {
      display: none;
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      justify-content: center;
    }
  }
</style>
