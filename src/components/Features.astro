---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    title: 'Emails',
    description: 'Messagerie collaborative intégrée pour centraliser tous vos échanges.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Contacts',
    description: 'Carnet d\'adresses unifié pour gérer clients, prospects et partenaires.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
    title: 'Tâches',
    description: 'Gestion des tâches et rappels pour ne rien laisser passer.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    title: 'Devis & Factures',
    description: 'Créez et suivez vos devis et factures en quelques clics.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    title: 'Calendrier',
    description: 'Planifiez vos rendez-vous et synchronisez avec votre agenda.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    title: 'Rapports',
    description: 'Tableaux de bord et statistiques pour piloter votre activité.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Automatisation',
    description: 'Campagnes email et SMS multicanal pour automatiser vos actions.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: 'Mobile',
    description: 'Applications iOS et Android pour travailler où que vous soyez.'
  },
];
---

<section class="section section--alt" id="fonctionnalites">
  <div class="container">
    <div class="section-header">
      <p class="label">Fonctionnalités</p>
      <h2 class="headline">Tout ce dont vous avez besoin pour gérer votre activité</h2>
      <p>Un logiciel CRM en ligne complet qui intègre messagerie et modules fonctionnels pour accompagner votre entreprise au quotidien.</p>
    </div>

    <div class="features__grid">
      {features.map(feature => (
        <div class="feature-card">
          <div class="feature-card__icon" set:html={feature.icon} />
          <h3 class="feature-card__title">{feature.title}</h3>
          <p class="feature-card__desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-6);
  }

  .feature-card {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: var(--sp-8);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .feature-card__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--dark-bg);
    border-radius: var(--radius-lg);
    margin-bottom: var(--sp-4);
    color: white;
  }

  .feature-card__title {
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: var(--sp-2);
    color: var(--on-surface);
  }

  .feature-card__desc {
    font-size: 0.875rem;
    color: var(--on-surface-variant);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
